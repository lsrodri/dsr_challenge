


import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns


# Load the dataset from the subfolder
df = pd.read_csv("src/data/raw/dengue_features_train.csv")


df.dtypes


df.shape





# missing values for numerical 

# 1. Show missing values per column
def report_missing_values(df):
    missing = df.isnull().sum()
    print("Missing values per column:")
    print(missing[missing > 0] if missing.any() else "No missing values.")

report_missing_values(df)





# inspect value range by column

def report_value_ranges(df):
    print("\nValue ranges (min–max) per column:")
    for col in df.columns:
        col_min = df[col].min()
        col_max = df[col].max()
        print(f"{col}: min = {col_min}, max = {col_max}")

report_value_ranges(df)


# 3. Create histograms for all numerical columns
def plot_histograms(df):
    df.hist(bins=20, figsize=(20, 15), edgecolor='black')
    plt.suptitle("Histograms of All Features", fontsize=16)
    plt.tight_layout()
    plt.show()

# 4. draw boxplot
def plot_boxplots(df):
    plt.figure(figsize=(20, len(df.columns) * 0.5))
    df.columns = df.columns.map(str)  # Ensure column names are strings
    df_melted = df.melt(var_name="Feature", value_name="Value")
    sns.boxplot(x="Value", y="Feature", data=df_melted, orient="h", palette="vlag")
    plt.title("Boxplots of All Features")
    plt.tight_layout()
    plt.show()

# Run all checks
plot_histograms(df)
plot_boxplots(df)



